\
function\cf5  \cf6 updatePlaylist\cf5 () \{\cb1 \
\cb4   \cf3 const\cf5  \cf6 folderName\cf5  = \cf7 "ESP32_AudioUploads"\cf5 ;\cb1 \
\cb4   \cf3 const\cf5  \cf6 playlistFileName\cf5  = \cf7 "playlist.txt"\cf5 ;\cb1 \
\
\cb4   \cf3 const\cf5  \cf6 folders\cf5  = \cf8 DriveApp\cf5 .\cf6 getFoldersByName\cf5 (\cf6 folderName\cf5 );\cb1 \
\cb4   \cf3 if\cf5  (!\cf6 folders\cf5 .\cf6 hasNext\cf5 ()) \{\cb1 \
\cb4     \cf8 Logger\cf5 .\cf6 log\cf5 (\cf7 "Folder not found: "\cf5  + \cf6 folderName\cf5 );\cb1 \
