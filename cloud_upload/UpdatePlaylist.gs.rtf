\
\cb4   \cf8 Logger\cf5 .\cf6 log\cf5 (\cf7 "Playlist has "\cf5  + \cf6 entries\cf5 .\cf6 length\cf5  + \cf7 " entries."\cf5 );\cb1 \
\cb4 \}\cb1 \
