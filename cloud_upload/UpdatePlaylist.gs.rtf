\cb4   \}\cb1 \
\
\cb4   \cf3 const\cf5  \cf6 folder\cf5  = \cf6 folders\cf5 .\cf6 next\cf5 ();\cb1 \
\cb4   \cf3 const\cf5  \cf6 files\cf5  = \cf6 folder\cf5 .\cf6 getFiles\cf5 ();\cb1 \
