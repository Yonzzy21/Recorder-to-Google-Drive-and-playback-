\cb4     \cf3 const\cf5  \cf6 file\cf5  = \cf6 files\cf5 .\cf6 next\cf5 ();\cb1 \
\cb4     \cf3 const\cf5  \cf6 name\cf5  = \cf6 file\cf5 .\cf6 getName\cf5 ();\cb1 \
\cb4     \cf3 if\cf5  (!\cf6 name\cf5 .\cf6 toLowerCase\cf5 ().\cf6 endsWith\cf5 (\cf7 ".wav"\cf5 )) \cf3 continue\cf5 ;\cb1 \
\
\cb4     \cf9 // Ensure file is public\cf5 \cb1 \
