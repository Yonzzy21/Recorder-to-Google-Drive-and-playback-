\cb4   \cf3 if\cf5  (\cf6 existing\cf5 .\cf6 hasNext\cf5 ()) \{\cb1 \
\cb4     \cf6 playlistFile\cf5  = \cf6 existing\cf5 .\cf6 next\cf5 ();\cb1 \
\cb4     \cf6 playlistFile\cf5 .\cf6 setContent\cf5 (\cf6 output\cf5 );  \cf9 // 
\f3 \uc0\u9989 
\f2  overwrite content\cf5 \cb1 \
\cb4     \cf8 Logger\cf5 .\cf6 log\cf5 (\cf7 "Updated existing playlist.txt"\cf5 );\cb1 \
\cb4   \} \cf3 else\cf5  \{\cb1 \
