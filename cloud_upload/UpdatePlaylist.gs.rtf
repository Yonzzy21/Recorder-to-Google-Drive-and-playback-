\cb4     \cf3 const\cf5  \cf6 fileId\cf5  = \cf6 file\cf5 .\cf6 getId\cf5 ();\cb1 \
\cb4     \cf3 const\cf5  \cf6 downloadLink\cf5  = \cf7 `https://drive.google.com/uc?export=download&id=\cf5 $\{\cf6 fileId\cf5 \}\cf7 `\cf5 ;\cb1 \
\cb4     \cf6 entries\cf5 .\cf6 push\cf5 (\cf7 `\cf5 $\{\cf6 name\cf5 \}\cf7 ,\cf5 $\{\cf6 downloadLink\cf5 \}\cf7 `\cf5 );\cb1 \
\cb4   \}\cb1 \
\
\cb4   \cf6 entries\cf5 .\cf6 sort\cf5 ();\cb1 \
\cb4   \cf3 const\cf5  \cf6 output\cf5  = \cf6 entries\cf5 .\cf6 join\cf5 (\cf7 "\\n"\cf5 );\cb1 \
\
\cb4   \cf9 // Overwrite existing playlist.txt or create it\cf5 \cb1 \
\cb4   \cf3 let\cf5  \cf6 playlistFile\cf5 ;\cb1 \
